{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "japan-travel-rag-mcp/contracts/mcp-tools.v1.json",
  "title": "MCP Tool Schemas v1 (Current Proxy Surface)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "search_messages": {
      "type": "object",
      "description": "Public input for search_messages. Caller must not send filters.chat_ids.",
      "additionalProperties": true,
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query string passed to upstream retrieval service"
        },
        "filters": {
          "type": "object",
          "description": "Optional filter object; chat_ids path is forbidden at public boundary",
          "additionalProperties": true
        }
      },
      "x_forbidden_paths": [
        "filters.chat_ids"
      ]
    },
    "get_message_context": {
      "type": "object",
      "description": "Get contextual neighborhood for a message UID.",
      "required": [
        "message_uid"
      ],
      "additionalProperties": true,
      "properties": {
        "message_uid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "get_related_messages": {
      "type": "object",
      "description": "Get related messages for a message UID.",
      "required": [
        "message_uid"
      ],
      "additionalProperties": true,
      "properties": {
        "message_uid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "list_sources": {
      "type": "object",
      "description": "List source records for provided message UIDs.",
      "required": [
        "message_uids"
      ],
      "additionalProperties": false,
      "properties": {
        "message_uids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
