{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "japan-travel-rag-mcp/contracts/mcp-tools.v1.json",
  "title": "MCP Tool Schemas v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "commonRouting": {
      "type": "object",
      "required": ["workspace_id", "region_pack_id", "source_list_version"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "region_pack_id": { "type": "string", "minLength": 1 },
        "source_list_version": { "type": "string", "minLength": 1 }
      }
    },
    "search_context": {
      "type": "object",
      "required": ["workspace_id", "region_pack_id", "source_list_version", "query"],
      "properties": {
        "workspace_id": { "type": "string" },
        "region_pack_id": { "type": "string" },
        "source_list_version": { "type": "string" },
        "query": { "type": "string", "minLength": 1 },
        "time_window": {
          "type": "object",
          "required": ["from", "to"],
          "properties": {
            "from": { "type": "string", "format": "date-time" },
            "to": { "type": "string", "format": "date-time" }
          }
        },
        "source_filters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lang_pref": {
          "type": "array",
          "items": { "type": "string" }
        },
        "require_outbound_links": { "type": "boolean" },
        "top_k": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "validate_google_map_link": {
      "type": "object",
      "required": ["workspace_id", "region_pack_id", "source_list_version", "url", "expected"],
      "properties": {
        "workspace_id": { "type": "string" },
        "region_pack_id": { "type": "string" },
        "source_list_version": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "expected": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "location": {
              "type": "object",
              "required": ["lat", "lon", "radius_m"],
              "properties": {
                "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                "lon": { "type": "number", "minimum": -180, "maximum": 180 },
                "radius_m": { "type": "number", "minimum": 1 }
              }
            },
            "category": { "type": "string" }
          }
        }
      }
    },
    "verify_tabelog": {
      "type": "object",
      "required": ["workspace_id", "region_pack_id", "source_list_version", "tabelog_url", "expected"],
      "properties": {
        "workspace_id": { "type": "string" },
        "region_pack_id": { "type": "string" },
        "source_list_version": { "type": "string" },
        "tabelog_url": { "type": "string", "format": "uri" },
        "expected": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "area": { "type": "string" },
            "category": { "type": "string" }
          }
        }
      }
    }
  }
}
