{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "japan-travel-rag-api-keys-usage",
  "title": "Japan Travel RAG - API Keys & Usage",
  "description": "API key lifecycle and tool usage monitoring",
  "tags": ["japan-travel-rag", "api-keys", "usage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Active Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Active\" FROM api_keys WHERE revoked_at IS NULL AND (expires_at IS NULL OR expires_at > NOW());",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "title": "Expired Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Expired\" FROM api_keys WHERE revoked_at IS NULL AND expires_at IS NOT NULL AND expires_at <= NOW();",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "Revoked Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Revoked\" FROM api_keys WHERE revoked_at IS NOT NULL;",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "API Keys",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "active": { "text": "active", "color": "green" }, "expired": { "text": "expired", "color": "yellow" }, "revoked": { "text": "revoked", "color": "red" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Created", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT key_prefix AS \"Prefix\", label AS \"Label\", CASE WHEN revoked_at IS NOT NULL THEN 'revoked' WHEN expires_at IS NOT NULL AND expires_at <= NOW() THEN 'expired' ELSE 'active' END AS \"Status\", created_at AS \"Created\", expires_at AS \"Expires\", revoked_at AS \"Revoked\" FROM api_keys ORDER BY created_at DESC;",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tool Usage Leaderboard",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT tool_name AS \"Tool\", SUM(call_count) AS \"Calls\" FROM usage_counters GROUP BY tool_name ORDER BY \"Calls\" DESC;",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top Users",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT user_id AS \"User\", SUM(call_count) AS \"Total Calls\" FROM usage_counters GROUP BY user_id ORDER BY \"Total Calls\" DESC LIMIT 10;",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Usage by User",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Calls", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT user_id AS \"User\", COUNT(DISTINCT tool_name) AS \"Tools Used\", SUM(call_count) AS \"Total Calls\", MAX(last_called_at) AS \"Last Active\" FROM usage_counters GROUP BY user_id ORDER BY \"Total Calls\" DESC;",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent Activity",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Last Called", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT user_id AS \"User\", tool_name AS \"Tool\", call_count AS \"Calls\", last_called_at AS \"Last Called\" FROM usage_counters WHERE last_called_at IS NOT NULL ORDER BY last_called_at DESC;",
          "format": "table"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
