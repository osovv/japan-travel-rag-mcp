{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "japan-travel-rag-system-overview",
  "title": "Japan Travel RAG - System Overview",
  "description": "High-level health dashboard for the Japan Travel RAG MCP system",
  "tags": ["japan-travel-rag", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Active Sources",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Active Sources\" FROM site_sources WHERE status = 'active';",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Pages",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Total Pages\" FROM site_pages;",
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Chunks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Total Chunks\" FROM site_chunks;",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Embeddings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Total Embeddings\" FROM site_chunk_embeddings;",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Embedding Coverage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT CASE WHEN COUNT(c.chunk_id) = 0 THEN 0 ELSE ROUND(COUNT(e.chunk_id)::numeric / COUNT(c.chunk_id)::numeric * 100, 1) END AS \"Coverage\" FROM site_chunks c LEFT JOIN site_chunk_embeddings e ON c.chunk_id = e.chunk_id;",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active API Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COUNT(*) AS \"Active API Keys\" FROM api_keys WHERE revoked_at IS NULL AND (expires_at IS NULL OR expires_at > NOW());",
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Tool Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT COALESCE(SUM(call_count), 0) AS \"Total Tool Calls\" FROM usage_counters;",
          "format": "table"
        }
      ]
    },
    {
      "id": 8,
      "title": "Source Health",
      "type": "table",
      "gridPos": { "h": 8, "w": 20, "x": 4, "y": 4 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "active": { "text": "active", "color": "green" }, "paused": { "text": "paused", "color": "yellow" }, "disabled": { "text": "disabled", "color": "red" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Source", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT s.name AS \"Source\", s.status AS \"Status\", s.domain AS \"Domain\", COUNT(DISTINCT p.page_id) AS \"Pages\", COUNT(DISTINCT c.chunk_id) AS \"Chunks\", j.last_status AS \"Last Crawl Status\", j.last_crawl AS \"Last Crawl\" FROM site_sources s LEFT JOIN site_pages p ON s.source_id = p.source_id LEFT JOIN site_chunks c ON p.page_id = c.page_id LEFT JOIN LATERAL ( SELECT status AS last_status, finished_at AS last_crawl FROM site_crawl_jobs WHERE source_id = s.source_id ORDER BY started_at DESC LIMIT 1 ) j ON true GROUP BY s.source_id, s.name, s.status, s.domain, j.last_status, j.last_crawl ORDER BY s.name;",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "title": "Crawl Activity (7d)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT date_trunc('day', started_at) AS time, status, COUNT(*) AS jobs FROM site_crawl_jobs WHERE started_at >= NOW() - INTERVAL '7 days' GROUP BY time, status ORDER BY time;",
          "format": "table"
        }
      ]
    },
    {
      "id": 10,
      "title": "Index Freshness",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Staleness" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "red", "value": 7 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Staleness", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT s.name AS \"Source\", MAX(p.fetched_at) AS \"Latest Fetch\", ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(p.fetched_at))) / 86400, 1) AS \"Staleness\" FROM site_sources s LEFT JOIN site_pages p ON s.source_id = p.source_id GROUP BY s.source_id, s.name ORDER BY \"Staleness\" DESC NULLS FIRST;",
          "format": "table"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
