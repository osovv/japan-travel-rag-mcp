# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://your-domain.example.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/japan_travel_rag

# ── Admin ─────────────────────────────────────────────────────────────────────
ROOT_AUTH_TOKEN=your-admin-root-token

# ── OAuth Session (FastMCP OAuth Proxy, min 32 chars) ─────────────────────────
OAUTH_SESSION_SECRET=generate-a-random-string-at-least-32-characters

# ── tg-chat-rag upstream ──────────────────────────────────────────────────────
TG_CHAT_RAG_BASE_URL=https://your-tg-chat-rag-api.example.com
TG_CHAT_RAG_BEARER_TOKEN=your-tg-chat-rag-bearer-token
# TG_CHAT_RAG_TIMEOUT_MS=15000

# ── Logto (MCP OAuth Proxy) ──────────────────────────────────────────────────
LOGTO_TENANT_URL=https://your-tenant.logto.app
LOGTO_CLIENT_ID=your-logto-mcp-app-client-id
LOGTO_CLIENT_SECRET=your-logto-mcp-app-client-secret

# ── Logto (Portal social login) ──────────────────────────────────────────────
PORTAL_SESSION_SECRET=your-portal-session-secret
# PORTAL_SESSION_TTL_SECONDS=604800
LOGTO_PORTAL_APP_ID=your-logto-portal-app-id
LOGTO_PORTAL_APP_SECRET=your-logto-portal-app-secret

# ── Logto (M2M provisioning — auto-assign MCP tester role) ───────────────────
LOGTO_M2M_APP_ID=your-logto-m2m-app-id
LOGTO_M2M_APP_SECRET=your-logto-m2m-app-secret
LOGTO_MANAGEMENT_API_RESOURCE=https://your-tenant.logto.app/api
LOGTO_MCP_USER_ROLE_ID=your-logto-mcp-user-role-id

# ── Unified Proxy (Spider + Voyage) ──────────────────────────────────────────
PROXY_BASE_URL=https://your-proxy.example.com
PROXY_SECRET=your-proxy-shared-secret
VOYAGE_API_KEY=your-voyage-api-key
SPIDER_API_KEY=your-spider-api-key
